# Klaxon — environment variables template
# Copy to .env and fill in. .env is gitignored.

# -------- 0G Chain (Guardian + iNFT contracts deployed here) --------
OG_CHAIN_RPC_URL=
OG_CHAIN_ID=
DEPLOYER_PRIVATE_KEY=
# 0G Storage
OG_STORAGE_RPC=
OG_STORAGE_INDEXER=

# -------- 0G Compute (Sealed Inference) --------
OG_COMPUTE_API_URL=
OG_COMPUTE_API_KEY=
OG_COMPUTE_MODEL=glm-5

# -------- Base Sepolia (x402 payments) --------
BASE_SEPOLIA_RPC_URL=
X402_FACILITATOR_URL=
X402_SESSION_KEY=

# -------- KeeperHub --------
KEEPERHUB_API_KEY=
KEEPERHUB_WORKFLOW_ID=
KEEPERHUB_MCP_URL=

# -------- AXL (per-node) --------
# Set in axl/node-a-config.json and axl/node-b-config.json, not here

# -------- Agent keys --------
# Three agent wallets for the 3-of-N quorum demo
AGENT_A_PRIVATE_KEY=
AGENT_B_PRIVATE_KEY=
AGENT_C_PRIVATE_KEY=

# -------- Deployed contract addresses (filled after Day 3 deploys) --------
GUARDIAN_ADDRESS=
VULNERABLE_POOL_ADDRESS=
AGENT_INFT_ADDRESS=
