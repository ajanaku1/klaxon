# Deployer key (also becomes Guardian owner + AgentINFT minter).
# 0G Chain testnet faucet was claimed to 0x6d4B...3df — use that key here.
PRIVATE_KEY=0x...

# 0G Chain testnet (Galileo). Confirm RPC + chain ID at docs.0g.ai before deploy.
ZEROG_TESTNET_RPC=https://evmrpc-testnet.0g.ai

# Base Sepolia (for x402 — Day 6, not Day 3)
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Agent signer addresses (secp256k1). Generate with `cast wallet new` — the
# AXL Ed25519 keys in axl/keys/ are SEPARATE; those are P2P transport only.
